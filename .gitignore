# ─── Dados (nunca versionar) ────────────────────────────────
# CSVs e bancos SQLite em qualquer lugar do projeto
*.csv
*.db

# Arquivos brutos grandes específicos (redundante com *.csv, mas explícito)
/data/raw/pns2019.csv
/data/raw/PNS_2019.txt

# ─── Backups e lixo ─────────────────────────────────────────
archive/
*.jar
*.zip

# ─── Temporários do MS Office (Word/Excel) ──────────────────
# Arquivos de lock/auto-save que o Word cria ao abrir um .docx (~$arquivo.docx)
# e os temporários de salvamento (~WRL####.tmp). Nunca devem ir pro repositório.
~$*
~WRL*.tmp
*.tmp

# ─── Ambientes e cache Python ───────────────────────────────
.venv/
.venv-1/
__pycache__/

# ─── Settings locais (per-máquina) ──────────────────────────
.claude/settings.local.json
.claude/worktrees/
